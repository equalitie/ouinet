FROM registry.gitlab.com/equalitie/ouinet
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      -o Dpkg::Options::="--force-confold" \
      libexpected-dev \
      librange-v3-dev \
      ninja-build \
      openjdk-17-jdk-headless \
      unzip \
      wget
ENV UNZIPOPT=-q
